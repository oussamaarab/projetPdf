APP_NAME=ConvertHub
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# No database – JSON-file storage only
DB_CONNECTION=null

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:5173

# ── Auth / Conversion settings ────────────────────────────────────────────────
API_TOKEN_TTL_MINUTES=120
ADMIN_EMAILS=

CONVERSION_TEMP_TTL_MINUTES=120
CONVERSION_MAX_UPLOAD_MB=250
CONVERSION_PROCESS_TIMEOUT=900

# ── Binary paths ──────────────────────────────────────────────────────────────
# On Linux / Docker these tools are on PATH, so the bare names work out of the box.
# On Windows set the full path to each executable.
#
# Linux (default – bare name resolved via `which`):
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
GHOSTSCRIPT_BINARY=gs
LIBREOFFICE_BINARY=soffice
IMAGEMAGICK_BINARY=magick
SEVEN_ZIP_BINARY=7z
UNRAR_BINARY=unrar
#
# Windows example values (uncomment and adjust as needed):
# FFMPEG_BINARY="C:/Program Files/FFmpeg/bin/ffmpeg.exe"
# FFPROBE_BINARY="C:/Program Files/FFmpeg/bin/ffprobe.exe"
# GHOSTSCRIPT_BINARY="C:/Program Files/gs/gs10.04.0/bin/gswin64c.exe"
# LIBREOFFICE_BINARY="C:/Program Files/LibreOffice/program/soffice.exe"
# IMAGEMAGICK_BINARY="C:/Program Files/ImageMagick-7.1.2-Q16-HDRI/magick.exe"
# SEVEN_ZIP_BINARY="C:/Program Files/7-Zip/7z.exe"
# UNRAR_BINARY="C:/Program Files/WinRAR/UnRAR.exe"
